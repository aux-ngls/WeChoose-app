{
  "name": "reliure",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --lan --port 8082",
    "dev:lan": "expo start --lan --port 8082",
    "dev:localhost": "expo start --localhost --port 8082",
    "dev:clear": "expo start --lan --port 8082 --clear",
    "dev:auto": "bash scripts/start-auto.sh",
    "dev:tunnel": "expo start --tunnel --port 8082",
    "dev:tunnel:clear": "rm -rf .expo && expo start --tunnel --port 8082 --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "update": "bash scripts/update-app.sh",
    "install:update": "bash scripts/install-or-update.sh",
    "typecheck": "tsc --noEmit",
    "verify": "bash scripts/verify.sh",
    "release": "bash scripts/package-release.sh",
    "release:fast": "RELIURE_SKIP_VERIFY=1 bash scripts/package-release.sh"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "expo": "~54.0.33",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  }
}
